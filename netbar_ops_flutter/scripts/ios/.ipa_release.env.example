# ============================================================================
# release_ios.sh 配置模板
# ----------------------------------------------------------------------------
# 真实配置文件名是 .ipa_release.env (去掉 .example), 由脚本运行时自动生成/维护,
# 已被 .gitignore 忽略, 切勿提交到 git。
#
# 你也可以手动复制本文件为 .ipa_release.env 并填好, 跳过脚本的交互询问。
# ============================================================================

# Apple 开发者团队 ID (10 位大写字母数字)。
# 在哪看: https://developer.apple.com/account -> Membership details -> Team ID
TEAM_ID=""

# App Store Connect API Key 的 Key ID。
# 它就是 .p8 文件名 AuthKey_<这部分>.p8 中间的那串。
KEY_ID=""

# App Store Connect API Key 的 Issuer ID (UUID 格式, 形如 57246542-96fe-1a63-e053-0824d011072a)。
# 在哪看: App Store Connect -> Users and Access -> Integrations -> App Store Connect API 页面顶部。
ISSUER_ID=""

# 上次成功上传的 build 号 (脚本自动维护, 用于保证下次严格递增)。首次留空。
LAST_BUILD=""

# 备注: 你的 .p8 私钥不放这里, 而是放在 ~/.appstoreconnect/private_keys/AuthKey_<KeyID>.p8
#       脚本会在阶段 B 帮你复制过去并 chmod 600。
